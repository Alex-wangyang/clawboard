# Clawboard runtime configuration
# Copy to .env and edit for your machine before running docker compose.

# Host port for the Clawboard web UI
CLAWBOARD_PORT=3180

# OpenClaw runtime data on the host
OPENCLAW_HOME=/Users/yourname/.openclaw

# Host home directory (used to map workspace paths into the container)
HOST_HOME=/Users/yourname

# Built-in OpenClaw skills directory on the host
OPENCLAW_BUILTIN_SKILLS_DIR=/opt/homebrew/lib/node_modules/openclaw/skills
